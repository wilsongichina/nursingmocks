                      ? "1px solid #c7d2fe"
                      : "1px solid transparent",
                  cursor: "pointer",
                  color: activeTab === "kb" ? "#4338ca" : "#6b7280",
                  background: activeTab === "kb" ? "#eef2ff" : "transparent",

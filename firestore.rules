rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    match /users/{userId} {
      allow read, create, update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /pages/{pageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /blogs/{blogId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /blogCategories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /pillarPages/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /knowledgeBase/{articleId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /questions/{questionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /questionTypes/{questionTypeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /questionCategories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /routeMappings/{mappingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
